# BaseOps API environment variables
# For ASP.NET Core, nested configuration keys use double underscores (__).

# ASP.NET Core environment (Development, Production, etc.)
ASPNETCORE_ENVIRONMENT=Development

# Database connection string
ConnectionStrings__BaseOpsConnection=Data Source=localhost;Initial Catalog=BaseOpsDev;Integrated Security=true;TrustServerCertificate=true;Encrypt=false;

# CORS allowed origins
Cors__AllowedOrigins__0=http://localhost:8080
Cors__AllowedOrigins__1=http://127.0.0.1:8080
Cors__AllowedOrigins__2=https://localhost:8080
Cors__AllowedOrigins__3=https://127.0.0.1:8080

# JWT settings
Jwt__Issuer=BaseOps
Jwt__Audience=BaseOps.Frontend
Jwt__SigningKey=CHANGE_ME_TO_A_64_BYTE_PRODUCTION_SECRET_CHANGE_ME_1234567890
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# Development seed admin password
DevelopmentSeed__AdminPassword=Admin@12345

# Optional host binding
AllowedHosts=*
