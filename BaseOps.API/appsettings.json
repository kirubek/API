{
  "ConnectionStrings": {
    "BaseOpsConnection": "Data Source=localhost;Initial Catalog=BaseOpsDev;Integrated Security=true;TrustServerCertificate=true;Encrypt=false;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8080",
      "http://127.0.0.1:8080",
      "https://localhost:8080",
      "https://127.0.0.1:8080"
    ]
  },
  "Jwt": {
    "Issuer": "BaseOps",
    "Audience": "BaseOps.Frontend",
    "SigningKey": "CHANGE_ME_TO_A_64_BYTE_PRODUCTION_SECRET_CHANGE_ME_1234567890",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "MediatR": "Error"
      }
    }
  },
  "AllowedHosts": "*"
}
